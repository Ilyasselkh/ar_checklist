<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_ar_checklist_documentation_list" model="ir.ui.view">
        <field name="name">ar.checklist.documentation.list</field>
        <field name="model">ar.checklist.documentation</field>
        <field name="arch" type="xml">
            <list>
                <field name="description"/>
                <field name="file_name"/>
                <field name="link_url"/>
                <field name="created_by"/>
                <field name="created_on"/>
            </list>
        </field>
    </record>

    <record id="view_ar_checklist_documentation_form" model="ir.ui.view">
        <field name="name">ar.checklist.documentation.form</field>
        <field name="model">ar.checklist.documentation</field>
        <field name="arch" type="xml">
            <form string="Documentation - Check-list de passation">
                <sheet>
                    <group>
                        <field name="description"/>
                        <field name="file_data" filename="file_name"/>
                        <field name="file_name" invisible="1"/>
                        <field name="link_url" placeholder="https://..."/>
                    </group>
                    <group string="Audit">
                        <field name="created_by" readonly="1"/>
                        <field name="created_on" readonly="1"/>
                    </group>
                    <chatter/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_ar_checklist_documentation" model="ir.actions.act_window">
        <field name="name">Documentation</field>
        <field name="res_model">ar.checklist.documentation</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
