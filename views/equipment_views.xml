<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_ar_checklist_equipment_list" model="ir.ui.view">
        <field name="name">ar.checklist.equipment.list</field>
        <field name="model">ar.checklist.equipment</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_ar_checklist_equipment_form" model="ir.ui.view">
        <field name="name">ar.checklist.equipment.form</field>
        <field name="model">ar.checklist.equipment</field>
        <field name="arch" type="xml">
            <form string="Équipement">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="sequence"/>
                        <field name="active"/>
                    </group>
                    <chatter/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_ar_checklist_equipment" model="ir.actions.act_window">
        <field name="name">Équipement</field>
        <field name="res_model">ar.checklist.equipment</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
