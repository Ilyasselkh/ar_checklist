<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_ar_checklist_client_list" model="ir.ui.view">
        <field name="name">ar.checklist.client.list</field>
        <field name="model">ar.checklist.client</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="excel_filename"/>
                <field name="create_uid"/>
                <field name="create_date"/>
            </list>
        </field>
    </record>

    <record id="view_ar_checklist_client_form" model="ir.ui.view">
        <field name="name">ar.checklist.client.form</field>
        <field name="model">ar.checklist.client</field>
        <field name="arch" type="xml">
            <form string="Clients">
                <header>
                    <button string="Convertir" name="action_convert_excel" type="object" class="btn-primary"/>
                </header>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="excel_file" filename="excel_filename"/>
                        <field name="excel_filename" invisible="1"/>
                    </group>
                    <group string="Tableau">
                        <field name="line_ids" nolabel="1">
                            <list editable="bottom">
                                <field name="name" string="Nom du client"/>
                            </list>
                        </field>
                    </group>
                    <chatter/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_ar_checklist_client" model="ir.actions.act_window">
        <field name="name">Clients</field>
        <field name="res_model">ar.checklist.client</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
