<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_ar_checklist_disagreement_wizard_form" model="ir.ui.view">
        <field name="name">ar.checklist.disagreement.wizard.form</field>
        <field name="model">ar.checklist.disagreement.wizard</field>
        <field name="arch" type="xml">
            <form string="Non d'accord" class="ar_disagreement_wizard">
                <div class="ar_disagreement_wizard_header">
                    <span class="ar_disagreement_wizard_badge">Signature 2</span>
                    <h2>Non d'accord</h2>
                    <p>Renseignez le motif du refus avant l'envoi vers l'état superviseur.</p>
                </div>
                <group class="ar_disagreement_wizard_body">
                    <field name="checklist_id" invisible="1"/>
                    <field name="motif" placeholder="Saisir le motif du refus..." required="1"/>
                </group>
                <footer>
                    <button name="action_confirm" string="Confirmer le refus" type="object" class="btn-danger"/>
                    <button string="Annuler" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
