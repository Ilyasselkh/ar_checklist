<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_ar_checklist_supervisor_decision_wizard_form" model="ir.ui.view">
        <field name="name">ar.checklist.supervisor.decision.wizard.form</field>
        <field name="model">ar.checklist.supervisor.decision.wizard</field>
        <field name="arch" type="xml">
            <form string="Décision superviseur" class="ar_supervisor_decision_wizard">
                <div class="ar_supervisor_wizard_header" invisible="decision != 'validated'">
                    <span class="ar_supervisor_wizard_badge ar_supervisor_wizard_badge_validate">Superviseur</span>
                    <h2>Valider la check-list</h2>
                    <p>Confirmez la validation finale. La check-list sera envoyée automatiquement dans l'archive.</p>
                </div>
                <div class="ar_supervisor_wizard_header ar_supervisor_wizard_header_refuse" invisible="decision != 'refused'">
                    <span class="ar_supervisor_wizard_badge ar_supervisor_wizard_badge_refuse">Superviseur</span>
                    <h2>Refuser la check-list</h2>
                    <p>Renseignez le motif de refus Superviseur. La check-list sera envoyée automatiquement dans l'archive.</p>
                </div>
                <group class="ar_supervisor_wizard_body">
                    <field name="checklist_id" invisible="1"/>
                    <field name="decision" invisible="1"/>
                    <field name="disagreement_motif" string="Motif de refus Opérateur" readonly="1" placeholder="Aucun motif Non d'accord renseigné."/>
                    <field name="motif" string="Motif de refus Superviseur" placeholder="Saisir le motif de refus Superviseur..." required="decision == 'refused'" invisible="decision != 'refused'"/>
                </group>
                <footer>
                    <button name="action_confirm" string="Valider" type="object" class="btn-success" invisible="decision != 'validated'"/>
                    <button name="action_confirm" string="Refuser" type="object" class="btn-danger" invisible="decision != 'refused'"/>
                    <button string="Annuler" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
